{
  "name": "koder",
  "version": "1.3.8",
  "description": "Koder bridge between Codex and the local Koder client. Run `koder up` to start.",
  "main": "src/index.js",
  "bin": {
    "koder": "./bin/koder.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node ./bin/koder.js up",
    "test": "node --test ./test/*.test.js",
    "postinstall": "node ./src/bootstrap-codex-cli.js",
    "prepack": "node ./scripts/prepare-private-defaults.js",
    "postpack": "node ./scripts/cleanup-private-defaults.js"
  },
  "keywords": [
    "koder",
    "codex",
    "bridge",
    "cli"
  ],
  "author": "Emanuele Di Pietro",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ws": "^8.19.0"
  }
}
